# 项目根目录环境变量示例

# 可选：多公司配置档案。留空时使用下面的默认变量。
# WECOM_ENV_PROFILE=COMPANY_A 或 COMPANY_B 时，企微脚本会优先读取对应公司配置。
# PEIFANG_ENV_PROFILE 可作为全平台默认档案；WECOM_ENV_PROFILE / FEISHU_ENV_PROFILE 可分别指定平台。
# 也可以把公司配置放到 .env.company_a、.env.wecom.company_a、.env.feishu.company_b 等本地文件。
PEIFANG_ENV_PROFILE=
WECOM_ENV_PROFILE=COMPANY_A
FEISHU_ENV_PROFILE=

# 企业微信群机器人
GROUP1_WEBHOOK=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=replace-me
GROUP2_WEBHOOK=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=replace-me

# 企业微信 / 智能表格默认兜底配置
WECOM_CORP_ID=wwxxxxxxxxxxxxxxxx
ADMIN_USERID=your_admin_userid
WECOM_APP_SECRET=replace-me
WECOM_APP_SECRETHYD=replace-me
WECOM_CALLBACK_TOKEN=replace-me
WECOM_CALLBACK_AESKEY=replace-me
WEDOC_DOCID=sample_docid
WEDOC_SHEET_ID=sample_sheet_id
WEDRIVE_SPACEIDS=space_id_1,space_id_2
SMARTSHEET_ID=sample_docid
SMARTSHEET_SHEET_ID=sample_sheet_id

# 企业微信公司 A
WECOM_COMPANY_A_CORP_ID=wwxxxxxxxxxxxxxxxx
WECOM_COMPANY_A_ADMIN_USERID=your_admin_userid
WECOM_COMPANY_A_APP_SECRET=replace-me
WECOM_COMPANY_A_APP_SECRETHYD=replace-me
WECOM_COMPANY_A_CALLBACK_TOKEN=replace-me
WECOM_COMPANY_A_CALLBACK_AESKEY=replace-me
WEDOC_COMPANY_A_DOCID=sample_docid_a
WEDOC_COMPANY_A_SHEET_ID=sample_sheet_id_a
WEDRIVE_COMPANY_A_SPACEIDS=space_id_1,space_id_2
SMARTSHEET_COMPANY_A_ID=sample_docid_a
SMARTSHEET_COMPANY_A_SHEET_ID=sample_sheet_id_a

# 企业微信公司 B
WECOM_COMPANY_B_CORP_ID=wwyyyyyyyyyyyyyyyy
WECOM_COMPANY_B_ADMIN_USERID=your_admin_userid
WECOM_COMPANY_B_APP_SECRET=replace-me
WECOM_COMPANY_B_APP_SECRETHYD=replace-me
WECOM_COMPANY_B_CALLBACK_TOKEN=replace-me
WECOM_COMPANY_B_CALLBACK_AESKEY=replace-me
WEDOC_COMPANY_B_DOCID=sample_docid_b
WEDOC_COMPANY_B_SHEET_ID=sample_sheet_id_b
WEDRIVE_COMPANY_B_SPACEIDS=space_id_1,space_id_2
SMARTSHEET_COMPANY_B_ID=sample_docid_b
SMARTSHEET_COMPANY_B_SHEET_ID=sample_sheet_id_b

# 飞书 / 多维表格默认配置
FEISHU_API_BASE=https://open.feishu.cn/open-apis
APP_ID=cli_xxxxxxxxxxxxxxxx
APP_SECRET=replace-me
APP_TOKEN=bascnxxxxxxxxxxxxxxxx
TABLE_ID=tblxxxxxxxxxxxxxxxx
VIEW_ID=vewxxxxxxxxxxxxxxxx
WIKI_URL=https://example.feishu.cn/wiki/your-page
WIKI_NODE_TOKEN=wikcnxxxxxxxxxxxxxxxx
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=replace-me

# 设置 FEISHU_ENV_PROFILE=COMPANY_B 时，会优先读取 FEISHU_COMPANY_B_*。
FEISHU_COMPANY_B_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_COMPANY_B_APP_SECRET=replace-me
FEISHU_COMPANY_B_APP_TOKEN=bascnxxxxxxxxxxxxxxxx
FEISHU_COMPANY_B_TABLE_ID=tblxxxxxxxxxxxxxxxx

# 本地数据输出目录
SAVE_PATH=./production_data_shengchan
