# 飞书（中国版）自建应用凭证
FEISHU_APP_ID=cli_xxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# 可选：默认拉取哪些群（逗号分隔 chat_id），不填则用命令行 --chat-id 或 /sync?chat_id=
FEISHU_TARGET_CHAT_IDS=

# 数据输出目录（相对路径或绝对路径）
FEISHU_DATA_DIR=./data

# messages 接口分页大小（1-50）
FEISHU_PAGE_SIZE=50

# 增量起点（可选，二选一即可）
# FEISHU_HISTORY_START_DAYS=7
# FEISHU_HISTORY_START_TIME=1700000000  # unix seconds
FEISHU_HISTORY_END_TIME=

# 日志级别：DEBUG / INFO / WARNING
FEISHU_LOG_LEVEL=INFO

# --- HTTP Server（可选：挂载路由手动触发 /sync） ---
FEISHU_SERVER_HOST=127.0.0.1
FEISHU_SERVER_PORT=8000
# 轮询自动拉取（0 或空 = 关闭；建议先关，验证 OK 再开）
FEISHU_POLL_INTERVAL_SECONDS=0

# --- 长连接（WebSocket SDK，可选：实时收 @机器人 消息） ---
# 启动 WS 前，是否先补拉一次历史增量（建议开）
FEISHU_WS_SYNC_ON_START=1
# 是否把每条事件落地到 data/events/*.jsonl（建议开，便于你验收）
FEISHU_WS_DUMP_EVENTS=1
# 是否自动回复（用于你验证“@机器人就生效”的链路；稳定后可关）
FEISHU_WS_AUTO_REPLY=1
# 回复前缀与最大长度（字符）
FEISHU_WS_REPLY_PREFIX=收到：
FEISHU_WS_REPLY_MAX_CHARS=300
